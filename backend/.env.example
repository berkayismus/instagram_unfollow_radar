# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ig_radar

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=30d

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Client ID from Google Cloud Console (Chrome Extension type)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ─── Paddle ───────────────────────────────────────────────────────────────────
# Paddle vendor auth code (from Paddle Dashboard → Developer Tools)
PADDLE_VENDOR_AUTH_CODE=your_paddle_vendor_auth_code
# Paddle webhook secret for signature validation
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
