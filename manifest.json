{
  "manifest_version": 3,
  "name": "Instagram Unfollow Radar",
  "version": "1.2.1",
  "description": "Automatically detect and unfollow users who don't follow you back on Instagram",
  "permissions": [
    "storage",
    "identity"
  ],
  "oauth2": {
    "client_id": "802490066850-di0g3l7dg7b5d2go49nc22fo3iftugjf.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  },
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://www.googleapis.com/*",
    "https://YOUR_BACKEND_DOMAIN/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "src/shared/constants.js",
        "src/shared/watchlistLimits.js",
        "src/content/api.js",
        "src/content/storage.js",
        "src/content/filters.js",
        "src/content/automation.js",
        "src/content/watchlist.js",
        "src/content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/index.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "locales/*.json"
      ],
      "matches": [
        "https://www.instagram.com/*"
      ]
    }
  ]
}
